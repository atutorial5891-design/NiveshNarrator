### storage/db_logger.py

```python
# Structured event log to RunLog table
# Called at start and end of each run_cycle() / run_pending()

def start_run(run_type: str, db: Session) -> RunLog:
    run = RunLog(
        run_id=str(uuid.uuid4()),
        run_type=run_type,
        started_at=datetime.utcnow(),
        status="running",
        content_ids=[],
    )
    db.add(run); db.commit()
    return run

def finish_run(run: RunLog, content_ids: list[str],
               status: str, error: str | None, db: Session) -> None:
    run.finished_at = datetime.utcnow()
    run.status = status
    run.content_ids = content_ids
    run.error = error
    db.commit()
```

### monitoring/sentry.py

```python
import sentry_sdk

def init_sentry() -> None:
    if settings.APP_ENV == "production":
        sentry_sdk.init(dsn=settings.SENTRY_DSN, traces_sample_rate=0.1)

def capture(exc: Exception, content_id: str | None = None) -> None:
    with sentry_sdk.push_scope() as scope:
        if content_id:
            scope.set_tag("content_id", content_id)
        sentry_sdk.capture_exception(exc)
```

