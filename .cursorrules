COUNTERS: dict[str, int] = {
    "personas_generated": 0,
    "scripts_generated": 0,
    "sebi_check1_pass": 0,
    "sebi_check2_pass": 0,
    "uploads_ok": 0,
    "uploads_failed": 0,
    "near_duplicates_rejected": 0,
}

def increment(key: str) -> None:
    COUNTERS[key] = COUNTERS.get(key, 0) + 1

def report() -> dict[str, int]:
    return dict(COUNTERS)
