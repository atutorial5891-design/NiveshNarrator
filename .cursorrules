---

### uploader.py  — SEBI gate + upload

```python
def upload(content_id: str, record: ContentRecord, ...) -> None:

    # MANDATORY gate — never bypass, never comment out
    if not record.sebi_check_1_passed or not record.sebi_check_2_passed:
        raise UploadError(
            f"[{content_id}] SEBI gate failed: "
            f"check_1={record.sebi_check_1_passed}, "
            f"check_2={record.sebi_check_2_passed}. Refusing upload."
        )

    # YouTube long-form
    # OAuth2 token from youtube_token.json (expires every 7 days)
    # On invalid_grant: raise UploadError with instructions to refresh token
    youtube_upload(video_path, metadata)

    # Instagram Reels (Shorts)
    # Step 1: Upload to S3, get public URL (Instagram needs public URL)
    s3_url = s3_upload_and_presign(shorts_path)
    # Step 2: Create media container via Instagram Graph API
    container_id = ig_create_container(s3_url)
    # Step 3: Poll until FINISHED — every 10s, max 300s
    for _ in range(30):
        time.sleep(10)
        status = ig_check_status(container_id)
        if status == "FINISHED":
            break
        if status == "ERROR":
            raise UploadError(f"[{content_id}] Instagram container errored")
    else:
        raise UploadError(f"[{content_id}] Instagram processing timeout after 300s")
    # Step 4: Publish
    ig_publish(container_id)
```

YouTube API notes:
  - Use Instagram Graph API — NOT Basic Display API
  - H.264 + AAC required — VP9 or HEVC causes indefinite PROCESSING state
  - Token refresh: re-run OAuth2 flow from setup instructions

### retry.py

```python
import functools, time, random

def with_retry(max_attempts: int = 4):
    def decorator(fn):
        @functools.wraps(fn)
        def wrapper(*args, **kwargs):
            for attempt in range(max_attempts):
                try:
                    return fn(*args, **kwargs)
                except DisclaimerMissingError:
                    raise   # NEVER retry this — propagate immediately
                except RetireBotError as e:
                    if attempt == max_attempts - 1:
                        raise
                    wait = (2 ** attempt) * (0.8 + random.random() * 0.4)  # ±20% jitter
                    logger.warning(f"Attempt {attempt + 1} failed: {e}. Retrying in {wait:.1f}s")
                    time.sleep(wait)
        return wrapper
    return decorator
```

