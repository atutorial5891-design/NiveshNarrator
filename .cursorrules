### core/models.py  (TypedDicts — no Pydantic here, keep it simple)
```python
from typing import TypedDict

class PersonaData(TypedDict):
    content_id: str          # UUIDv4 string — generated in persona.py
    first_name: str
    last_name: str
    age: int                 # 35–50
    city: str
    job_type: str            # see job_type values in STAGE 3
    monthly_ctc: int         # ₹ CTC per month
    monthly_basic: int       # CTC × 0.40
    existing_savings: int    # liquid savings at generation time
    monthly_expenses: int    # current monthly spend
    years_experience: int    # 5–25
    years_to_retirement: int # RETIREMENT_AGE − age

class RetirementMath(TypedDict):
    content_id: str
    monthly_take_home: int
    annual_take_home: int
    employee_epf_monthly: int
    employer_epf_monthly: int
    epf_corpus: int
    nps_corpus: int           # 0 for non-PSU job types
    monthly_pension: int      # 0 for non-pre2004-PSU job types
    grown_savings: int
    target_corpus: int
    monthly_sip: int
    instrument_split: dict    # must contain both _pct and _monthly_inr keys
    sebi_disclaimer: str      # injected by validator.py (SEBI Check 1)

class OverlaySpec(TypedDict):
    timestamp_start: float   # seconds into audio
    timestamp_end: float
    context_phrase: str      # spoken phrase matched via SequenceMatcher
    display_text: str        # ₹-formatted figure to show on screen
```

