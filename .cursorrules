### config.py  (pydantic-settings)
```python
from pydantic_settings import BaseSettings

class Settings(BaseSettings):
    # API keys
    ANTHROPIC_API_KEY: str
    ELEVENLABS_API_KEY: str
    ELEVENLABS_VOICE_ID: str
    OPENAI_API_KEY: str
    YOUTUBE_API_KEY: str
    YOUTUBE_CHANNEL_ID: str
    AWS_ACCESS_KEY_ID: str
    AWS_SECRET_ACCESS_KEY: str
    AWS_S3_BUCKET: str = "retirebot-outputs"
    AWS_REGION: str = "ap-south-1"
    INSTAGRAM_ACCESS_TOKEN: str
    INSTAGRAM_BUSINESS_ACCOUNT_ID: str

    # Financial rates — update from .env, never hardcode
    EPF_RATE: float = 0.0825
    PPF_RATE: float = 0.071
    NPS_EQUITY_RATE: float = 0.12
    NPS_DEBT_RATE: float = 0.075
    INFLATION_RATE: float = 0.06
    SAFE_WITHDRAWAL_RATE: float = 0.033   # NEVER change to 0.04
    EQUITY_MF_RATE: float = 0.12
    STANDARD_DEDUCTION: int = 75000
    RETIREMENT_AGE: int = 60              # NEVER change

    # Pipeline thresholds
    NEAR_DUPLICATE_THRESHOLD: float = 0.85
    SEBI_DISCLAIMER_PHRASE: str
    SIP_FLOOR: int = 500
    SIP_CEILING: int = 200000

    # App
    APP_ENV: str = "development"
    TEMP_DIR: Path = Path("/tmp/niveshnarrator")
    DATABASE_URL: str = "sqlite:///./niveshnarrator.db"

    class Config:
        env_file = ".env"
```

### core/database.py
```python
# ContentStatus enum — enforce in orchestrator state machine
class ContentStatus(str, Enum):
    PERSONA_GENERATED = "persona_generated"
    MATH_CALCULATED   = "math_calculated"
    MATH_VALIDATED    = "math_validated"
    SCRIPT_GENERATED  = "script_generated"
    SCRIPT_VALIDATED  = "script_validated"
    PENDING_REVIEW    = "pending_review"
    APPROVED          = "approved"
    REJECTED_REVIEW   = "rejected_review"
    SHORTS_WRITTEN    = "shorts_written"
    PRODUCED          = "produced"
    UPLOADED          = "uploaded"
    FAILED            = "failed"

# ContentRecord — main pipeline table
class ContentRecord(Base):
    __tablename__ = "content_records"
    content_id            = Column(String, primary_key=True)    # UUIDv4
    persona_hash          = Column(String, index=True)
    status                = Column(Enum(ContentStatus))
    sebi_check_1_passed   = Column(Boolean, default=False)
    sebi_check_2_passed   = Column(Boolean, default=False)
    regeneration_count    = Column(Integer, default=0)
    reject_reason         = Column(String, nullable=True)
    persona_json          = Column(JSON)
    math_json             = Column(JSON)
    script_text           = Column(Text, nullable=True)
    shorts_script_text    = Column(Text, nullable=True)
    yt_video_id           = Column(String, nullable=True)
    ig_media_id           = Column(String, nullable=True)
    yt_views              = Column(Integer, default=0)
    yt_ctr                = Column(Float, default=0.0)
    yt_avg_watch_pct      = Column(Float, default=0.0)
    created_at            = Column(DateTime, default=func.now())
    updated_at            = Column(DateTime, default=func.now(), onupdate=func.now())

# RunLog — one row per pipeline run (for ops visibility)
class RunLog(Base):
    __tablename__ = "run_logs"
    run_id      = Column(String, primary_key=True)   # UUIDv4
    run_type    = Column(String)                      # "cycle" | "pending" | "manual"
    started_at  = Column(DateTime)
    finished_at = Column(DateTime, nullable=True)
    status      = Column(String)                      # "ok" | "partial" | "failed"
    content_ids = Column(JSON)                        # list of content_ids processed
    error       = Column(Text, nullable=True)

# get_db() — always use as context manager
@contextmanager
def get_db() -> Generator[Session, None, None]:
    session = SessionLocal()
    try:
        yield session
        session.commit()
    except Exception:
        session.rollback()
        raise
    finally:
        session.close()
```

Test gate: `pytest tests/test_core.py -v` — must be green before Stage 2.

