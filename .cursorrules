### shorts_writer.py  — only after APPROVED

```python
# CALLED ONLY when record.status == ContentStatus.APPROVED
# NEVER from an unapproved record

def write_shorts_script(content_id: str, long_form_script: str,
                        math: RetirementMath) -> str:
    # Validate short disclaimer file before generation
    short_path = Path("assets/sebi/sebi_disclaimer_short.txt")
    if not short_path.exists() or short_path.stat().st_size == 0:
        raise DisclaimerMissingError("sebi_disclaimer_short.txt missing or empty")
    short_disclaimer = short_path.read_text().strip()

    # Generate via claude-sonnet-4-6 — same model as long-form
    # Target: 130–145 words
    # Must contain key figures consistent with long-form
    # Must end with short_disclaimer (verbatim)

    wc = len(shorts_script.split())
    if wc > 145:
        raise OutputValidationError(f"Shorts script {wc} words — max 145")
    return shorts_script
```

