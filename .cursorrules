## PYTHON CODING STANDARDS  (every single file, no exceptions)

```python
# ── Module template ──────────────────────────────────────────
from core.logger import get_logger          # import 1
logger = get_logger(__name__)               # line 2 — ALWAYS before any logic

# ── Logging ── every message must carry content_id ───────────
logger.info(f"[{content_id}] Starting corpus calculation")
logger.warning(f"[{content_id}] EPF employer cap applied at ₹1800")
logger.error(f"[{content_id}] SEBI check 2 failed — halting")

# Never use print() — always logger

# ── Type hints — full, on every parameter and return ─────────
def calculate_corpus(
    persona: PersonaData,
    settings: Settings,
) -> RetirementMath:

# ── File paths — pathlib only, never raw strings ─────────────
output_path: Path = settings.TEMP_DIR / f"{content_id}_chart.png"

# ── Database — always context manager ────────────────────────
with get_db() as db:
    record = db.query(ContentRecord).filter_by(content_id=content_id).first()

# ── External API calls — try/except with project exceptions ──
try:
    response = elevenlabs_client.generate(text=script, voice=voice_id)
except Exception as e:
    raise TTSError(f"[{content_id}] ElevenLabs failed: {e}") from e

# ── Subprocess (FFmpeg) ───────────────────────────────────────
result = subprocess.run(
    ["ffmpeg", "-i", str(input_path), "-c:v", "libx264", str(output_path)],
    capture_output=True,
    text=True,
)
if result.returncode != 0:
    raise ComposerError(f"[{content_id}] FFmpeg failed:\n{result.stderr}")

# ── Temp file cleanup — always in finally ────────────────────
try:
    produce_video()
finally:
    temp_audio.unlink(missing_ok=True)
    temp_chart.unlink(missing_ok=True)

# ── Settings — never hardcode rates, limits, or paths ────────
# WRONG:  if monthly_sip < 500:
# RIGHT:  if monthly_sip < settings.SIP_FLOOR:

# ── Python version features ───────────────────────────────────
# Python 3.11+ — use match/case, X | Y union types, built-in Path
match job_type:
    case "psu_post2004":
        nps_corpus = calculate_nps(persona, settings)
    case "psu_pre2004":
        pension = calculate_pension(persona, settings)
    case _:
        pass   # private sector — EPF only
```

