# Bucket: retirebot-outputs in ap-south-1
# Policy: public-read (required for Instagram Graph API)
# Use boto3 — always catch ClientError

def upload_video(local_path: Path, content_id: str) -> str:
    key = f"videos/{content_id}/{local_path.name}"
    s3_client.upload_file(str(local_path), settings.AWS_S3_BUCKET, key)
    url = s3_client.generate_presigned_url("get_object",
              Params={"Bucket": settings.AWS_S3_BUCKET, "Key": key},
              ExpiresIn=3600)
    return url
