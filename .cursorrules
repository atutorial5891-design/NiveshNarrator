    except Exception as e:
        results["db"] = f"error: {e}"
    # Check S3
    try:
        s3_client.head_bucket(Bucket=settings.AWS_S3_BUCKET)
        results["s3"] = "ok"
    except Exception as e:
        results["s3"] = f"error: {e}"
    return results
```

---

## STAGE 9 — ORCHESTRATOR & CLI

### orchestrator.py — full state machine

```python
def run_cycle(dry_run: bool = False) -> None:
    """
    Runs at 10:00 IST and 20:00 IST.
    Generates personas + scripts. Does NOT produce media or upload.
    """
    with get_db() as db:
        run = db_logger.start_run("cycle", db)
        processed = []
        try:
            for _ in range(settings.CYCLE_BATCH_SIZE):   # default 2 per cycle
                try:
                    # 1. Generate persona
                    persona = persona_module.generate(db)         # → PERSONA_GENERATED
                    cid = persona["content_id"]
                    processed.append(cid)
                    # 2. Math
                    math = run_calculate(persona, db)             # → MATH_CALCULATED
                    # 3. Validate math
                    validated = validator.validate(math, db)      # → MATH_VALIDATED
                    # 4. Script
                    script = scriptwriter.write(persona, math, db) # → SCRIPT_GENERATED
                    # 5. Validate script
                    script_validator.validate(script, math, db)   # → SCRIPT_VALIDATED
                    # 6. Queue for review
                    set_status(cid, PENDING_REVIEW, db)
                    logger.info(f"[{cid}] Queued for human review")
                except (PersonaExhaustedError, PersonaNearDuplicateError) as e:
                    logger.warning(f"Persona skipped: {e}")
                    continue
                except DisclaimerMissingError:
                    logger.error("DisclaimerMissingError — check write.log. No auto-retry.")
                    set_status(cid, FAILED, db)
                except RetireBotError as e:
                    logger.error(f"[{cid}] Stage failed: {e}")
                    set_status(cid, FAILED, db)
            db_logger.finish_run(run, processed, "ok", None, db)
        except Exception as e:
            db_logger.finish_run(run, processed, "failed", str(e), db)
            monitoring.capture(e)
            raise


def run_pending(dry_run: bool = False) -> None:
    """
    Runs at 14:00 IST and 21:00 IST.
    Produces + publishes APPROVED records. Never runs on unapproved content.
    """
    with get_db() as db:
        approved = actions.get_approved_records(db)
        for record in approved:
            cid = record.content_id
            try:
                persona = PersonaData(**json.loads(record.persona_json))
                math    = RetirementMath(**json.loads(record.math_json))
                # 1. Shorts script (only after approval)
                shorts = shorts_writer.write(cid, record.script_text, math) # → SHORTS_WRITTEN
                # 2. Produce all media
                produce_all(cid, record, persona, math, shorts)             # → PRODUCED
                # 3. Upload
                if not dry_run:
                    uploader.upload(cid, record, ...)                       # → UPLOADED
                else:
                    logger.info(f"[{cid}] dry_run=True — skipping upload")
                # 4. Cleanup
                cleanup.cleanup_temp(cid)
            except RetireBotError as e:
                logger.error(f"[{cid}] Production failed: {e}")
                set_status(cid, FAILED, db)
                monitoring.capture(e, cid)
```

Status machine — enforce strictly, no shortcutting:
```
PERSONA_GENERATED → MATH_CALCULATED → MATH_VALIDATED →
SCRIPT_GENERATED  → SCRIPT_VALIDATED → PENDING_REVIEW →
APPROVED → SHORTS_WRITTEN → PRODUCED → UPLOADED
         ↘ REJECTED_REVIEW (max 3 times, then → FAILED)
Any stage ↘ FAILED  (unrecoverable — check logs for content_id)
```

### Scheduling — cron setup (IST = UTC+5:30)

Add to crontab (`crontab -e`) on the machine running the pipeline:
```cron
# run_cycle — 10:00 IST (04:30 UTC) and 20:00 IST (14:30 UTC)
30 4  * * *  cd /path/to/NiveshNarrator && APP_ENV=production python main.py --run-cycle >> logs/cron.log 2>&1
30 14 * * *  cd /path/to/NiveshNarrator && APP_ENV=production python main.py --run-cycle >> logs/cron.log 2>&1

# run_pending — 14:00 IST (08:30 UTC) and 21:00 IST (15:30 UTC)
30 8  * * *  cd /path/to/NiveshNarrator && APP_ENV=production python main.py --run-pending >> logs/cron.log 2>&1
30 15 * * *  cd /path/to/NiveshNarrator && APP_ENV=production python main.py --run-pending >> logs/cron.log 2>&1
```

### main.py — CLI entry point

```python
import argparse

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--run-cycle",   action="store_true")
    parser.add_argument("--run-pending", action="store_true")
    parser.add_argument("--dashboard",   action="store_true")
    parser.add_argument("--content-id",  type=str)
    parser.add_argument("--stage",       type=str,
                        choices=["calculate", "write", "produce", "publish"])
    parser.add_argument("--dry-run",     action="store_true")

    args = parser.parse_args()

    if args.run_cycle:
        orchestrator.run_cycle(dry_run=args.dry_run)
    elif args.run_pending:
        orchestrator.run_pending(dry_run=args.dry_run)
    elif args.dashboard:
        import subprocess
        subprocess.run(["streamlit", "run", "pipeline/review/dashboard.py"])
    elif args.content_id and args.stage:
        run_single_stage(args.content_id, args.stage, dry_run=args.dry_run)
    elif args.content_id and args.dry_run:
        run_single_end_to_end(args.content_id, dry_run=True)
```

APP_ENV behaviour:
  `development` — DEBUG logging, dry_run=True by default, SQLite
  `production`  — INFO logging, dry_run=False by default, Postgres or SQLite

**Always use `--dry-run` when testing. There is no staging YouTube channel.**

